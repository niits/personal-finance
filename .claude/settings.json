{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git push*)",
            "command": "cd /home/niits/workspace/personal-finance && npm run test:unit -- --reporter=dot 2>&1; exit $?",
            "timeout": 120,
            "statusMessage": "Running unit tests before push..."
          }
        ]
      }
    ]
  }
}
