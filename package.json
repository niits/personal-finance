{
  "name": "personal-finance",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "firebase emulators:exec --only auth,firestore --project=demo-personal-finance \"vitest run --config vitest.config.ts\"",
    "test:integration:nofire": "vitest run --config vitest.config.ts",
    "test": "npm run test:unit && npm run test:integration",
    "test:e2e": "firebase emulators:exec --only auth,firestore --project=demo-personal-finance \"npx playwright test\"",
    "test:e2e:nofire": "npx playwright test",
    "firestore:deploy": "firebase deploy --only firestore:rules,firestore:indexes"
  },
  "dependencies": {
    "firebase": "^11.7.0",
    "firebase-admin": "^13.2.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "firebase-tools": "^14.0.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
