{
  "name": "personal-finance",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "build:cf": "opennextjs-cloudflare build",
    "dev:cf": "opennextjs-cloudflare build && opennextjs-cloudflare preview -- --port 8787",
    "preview:cf": "opennextjs-cloudflare preview -- --port 8787 --local",
    "deploy:cf": "opennextjs-cloudflare build && opennextjs-cloudflare deploy -- --env production",
    "deploy:staging": "opennextjs-cloudflare build && opennextjs-cloudflare deploy -- --env staging",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test": "npm run test:unit",
    "icons": "node scripts/generate-icons.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.64",
    "@anthropic-ai/sdk": "^0.93.0",
    "@better-auth/cli": "^1.4.21",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "ai": "^6.0.175",
    "better-auth": "^1.6.9",
    "kysely": "^0.28.16",
    "kysely-d1": "^0.4.0",
    "langfuse-vercel": "^3.38.20",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-vega": "^8.0.0",
    "swr": "^2.4.1",
    "vega": "^6.2.0",
    "vega-embed": "^7.1.0",
    "vega-lite": "^6.4.3",
    "workers-ai-provider": "^3.1.13"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.71",
    "@opennextjs/cloudflare": "^1.19.4",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-a11y": "^10.4.0",
    "@storybook/nextjs": "^10.4.0",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "storybook": "^10.4.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4",
    "wrangler": "^4.86.0"
  }
}
